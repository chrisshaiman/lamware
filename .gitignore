# Terraform
**/.terraform/
*.tfstate.backup
*.tfplan
tfplan
.terraform.lock.hcl
terraform.tfvars
!terraform.tfvars.example

# Remote state files — all ignored (including bootstrap local state; contains account IDs)
*.tfstate

# Packer
packer/output/
packer/output-guest/
packer/output-office/
packer/packer_cache/
packer/packer.auto.pkrvars.hcl
packer/scripts/boot-helper.sh

# Ansible
ansible/inventory/hosts
ansible/inventory/local-test
ansible/*.retry
*.log

# Environment-specific files filled in during deployment (contain account IDs / ARNs)
shared/backend-aws.hcl
!shared/backend-aws.hcl.example
ansible/vars/main.yml
!ansible/vars/main.yml.example
packer/http/user-data
!packer/http/user-data.example

# Claude Code project context (developer-specific, not for public repo)
CLAUDE.md

# Secrets / local config
.env
*.pem
*.key
!*.key.example
# Exclude a top-level wireguard/ directory (generated key files), not the Ansible role
/wireguard/

# Python
__pycache__/
*.pyc
*.pyo
.venv/

# Superpowers plans (developer-specific, not for public repo)
docs/superpowers/

# OS
.DS_Store
*.swp
