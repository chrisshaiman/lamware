---
# =============================================================================
# vars/secrets.yml — Sensitive variables (gitignored)
#
# Copy this file to secrets.yml and fill in real values:
#   cp secrets.yml.example secrets.yml
#
# Then encrypt with ansible-vault:
#   ansible-vault encrypt ansible/vars/secrets.yml
#
# To run playbooks:
#   ansible-playbook site.yml --ask-vault-pass
#   OR
#   ansible-playbook site.yml --vault-password-file ~/.vault_pass
# =============================================================================

# Cape API key — used by api.conf for authenticated sample submission.
# Generate from Cape web UI: Settings > API > Generate Token
cape_api_key: ""

# MalwareBazaar API key — free auth key from https://auth.abuse.ch/
# Used by sample-feeder CLI to query and download samples.
bazaar_auth_key: ""
