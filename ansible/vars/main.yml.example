---
# =============================================================================
# vars/main.yml — All tuneable variables
# Sensitive values (dsdt_string, cape_api_key, etc.) should be pulled
# from AWS Secrets Manager at runtime, not stored here.
# Use ansible-vault or pass via --extra-vars for local overrides.
# =============================================================================

# -----------------------------------------------------------------------------
# Host identity
# -----------------------------------------------------------------------------
sandbox_hostname: malware-sandbox-01

# -----------------------------------------------------------------------------
# Networking — detonation bridge
# This network is air-gapped. Guests detonate here, INetSim listens here.
# No route to management plane or internet.
# -----------------------------------------------------------------------------
detonation_bridge: virbr-det
detonation_network: 192.168.100.0/24
detonation_gateway: 192.168.100.1
detonation_dhcp_start: 192.168.100.10
detonation_dhcp_end: 192.168.100.50

# Management interface (adjust if provider uses different name)
management_interface: eth0

# -----------------------------------------------------------------------------
# WireGuard
# -----------------------------------------------------------------------------
wireguard_interface: wg0
wireguard_address: 10.200.0.1/24
wireguard_port: 51820
# Operator laptop's WireGuard public key — generate with:
#   wg genkey | tee ~/wg-private.key | wg pubkey > ~/wg-public.key
# Host keypair is generated on the server by Ansible (never leaves the host).
wireguard_peer_pubkey: ""

# -----------------------------------------------------------------------------
# Cape
# -----------------------------------------------------------------------------
cape_user: cape
cape_install_dir: /opt/CAPEv2
cape_result_ip: "{{ detonation_gateway }}"
cape_interface: "{{ detonation_bridge }}"

# DSDT string — hardware-specific, pulled from Secrets Manager at runtime
# This is what defeats VM fingerprinting. Must match the actual host hardware.
# cape_dsdt_string: pulled from Secrets Manager

# -----------------------------------------------------------------------------
# AWS / S3
# Fill these in from terraform output after AWS infra is deployed:
#   terraform -chdir=aws/envs/prod output -raw samples_bucket_name
#   terraform -chdir=aws/envs/prod output -raw reports_bucket_name
# -----------------------------------------------------------------------------
aws_region: us-east-1
s3_bucket_samples: ""         # fill from: terraform output -raw samples_bucket_name
s3_bucket_reports: ""         # fill from: terraform output -raw reports_bucket_name

# -----------------------------------------------------------------------------
# Cape API
# -----------------------------------------------------------------------------
cape_api_port: 8000
# Cape API URL as seen from the bare metal host (wg0 IP, local loopback to same machine)
cape_api_url: "http://{{ wireguard_address | ansible.utils.ipaddr('address') }}:{{ cape_api_port }}/apiv2"

# WireGuard peer — operator laptop tunnel address (AllowedIPs in server peer block)
wireguard_peer_address: 10.200.0.2/32

# -----------------------------------------------------------------------------
# Secrets Manager ARNs — set these to match your AWS deployment
# Run: terraform -chdir=aws/envs/prod output  to get the ARNs
# -----------------------------------------------------------------------------
secrets_manager_region: us-east-1
secret_arn_baremetal: ""      # fill from: terraform output -raw baremetal_agent_secret_arn
secret_arn_cape: ""           # fill after manually creating Cape API key secret in AWS

# -----------------------------------------------------------------------------
# Cape guest VM definitions (ADR-012, ADR-013)
# Each entry defines one libvirt domain and one kvm.conf machine stanza.
# The `name` field is both the libvirt domain name and the kvm.conf section.
#
# Prerequisites before running Ansible with these defined:
#   1. Copy the Packer-built qcow2 files to the bare metal host:
#        scp packer/output/windows10-guest.qcow2  root@<host>:/var/lib/libvirt/images/
#        scp packer/output/windows10-office.qcow2 root@<host>:/var/lib/libvirt/images/
#   2. Run Ansible (it will define the libvirt domains)
#   3. Start each VM, verify cape-agent.py is listening on port 8000
#   4. Take the named snapshot from the host:
#        virsh snapshot-create-as clean  --name clean  --disk-only --atomic
#        virsh snapshot-create-as office --name office --disk-only --atomic
#   5. Shut down the VM — Cape restores from snapshot for each analysis
#
# MAC addresses: locally administered, unicast (02:xx:xx:xx:xx:xx range).
# Use stable values so DHCP leases on virbr-det are deterministic.
# -----------------------------------------------------------------------------
cape_guests:
  - name: clean
    disk_path: "{{ cape_guest_image_dir }}/windows10-guest.qcow2"
    snapshot: clean
    ip: "{{ detonation_dhcp_start }}"   # 192.168.100.10 — first DHCP address
    mac: "02:ca:fe:00:00:10"
    # tags: empty — clean is the default machine for untagged submissions
    conf_options:
      - { key: label,              value: clean }
      - { key: platform,           value: windows }
      - { key: ip,                 value: "{{ detonation_dhcp_start }}" }
      - { key: snapshot,           value: clean }
      - { key: interface,          value: "{{ detonation_bridge }}" }
      - { key: resultserver_ip,    value: "{{ detonation_gateway }}" }
      - { key: resultserver_port,  value: "{{ cape_resultserver_port }}" }
      - { key: tags,               value: "" }

  - name: office
    disk_path: "{{ cape_guest_image_dir }}/windows10-office.qcow2"
    snapshot: office
    ip: "192.168.100.11"
    mac: "02:ca:fe:00:00:11"
    # tags: office — matched when the submitter includes tag "office".
    # sample_submitter.py (Lambda) adds this tag for .doc/.docm/.xls/.xlsm/.odt
    conf_options:
      - { key: label,              value: office }
      - { key: platform,           value: windows }
      - { key: ip,                 value: "192.168.100.11" }
      - { key: snapshot,           value: office }
      - { key: interface,          value: "{{ detonation_bridge }}" }
      - { key: resultserver_ip,    value: "{{ detonation_gateway }}" }
      - { key: resultserver_port,  value: "{{ cape_resultserver_port }}" }
      - { key: tags,               value: office }
