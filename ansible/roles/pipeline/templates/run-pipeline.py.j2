#!/usr/bin/env python3
"""
Pipeline orchestrator — runs the four-stage malware analysis pipeline.

Stage 1: Triage (always) — containerized YARA/ssdeep/FLOSS via run-triage
Stage 2: Dynamic (always) — submit to Cape API, poll until complete
Stage 3: Memory forensics (triggered) — Volatility 3 (stub until sub-project 3)
Stage 4: Static deep-dive (triggered) — Ghidra headless (stub until sub-project 4)

Usage:
  run-pipeline <sample_path>
  run-pipeline <sample_path> --task-id <id>

Output: /opt/pipeline/reports/<task_id>/report.json

Author: Christopher Shaiman
License: Apache 2.0
"""

import argparse
import json
import os
import subprocess
import sys
import time
import uuid
from datetime import datetime, timezone
from pathlib import Path

import requests


# -------------------------------------------------------------------------
# Configuration (injected by Ansible template)
# -------------------------------------------------------------------------

CAPE_API_URL = "{{ cape_api_url }}"
CAPE_API_KEY = "{{ cape_api_key }}"
TRIAGE_CMD = "{{ triage_install_dir }}/run-triage"
VOLATILITY_CMD = "{{ volatility_install_dir }}/run-volatility"
REPORTS_DIR = Path("{{ pipeline_reports_dir }}")
CAPE_POLL_INTERVAL = {{ pipeline_cape_poll_interval }}
CAPE_TIMEOUT = {{ pipeline_cape_timeout }}

# Volatility trigger signatures — Cape signature names that trigger Stage 3
VOLATILITY_TRIGGERS = {{ pipeline_volatility_triggers | to_json }}

# Standard Volatility plugins (always run when triggered)
VOLATILITY_STANDARD_PLUGINS = [
    "windows.psscan",
    "windows.pstree",
    "windows.malfind",
    "windows.cmdline",
    "windows.netscan",
    "windows.dlllist",
]

# Extra plugins mapped by trigger category
VOLATILITY_EXTRA_PLUGINS = {{ pipeline_volatility_extra_plugins | default({}) | to_json }}


# -------------------------------------------------------------------------
# Stage 1: Triage (always)
# -------------------------------------------------------------------------

def run_triage(sample_path: Path, output_dir: Path) -> dict:
    """Run containerized triage analysis. Returns triage JSON."""
    try:
        result = subprocess.run(
            [TRIAGE_CMD, str(sample_path), str(output_dir)],
            capture_output=True,
            text=True,
            timeout=300,
        )
        if result.returncode != 0:
            print(f"  [!] Triage failed: {result.stderr[:200]}", file=sys.stderr)
            return {"error": "triage failed", "stderr": result.stderr[:500]}
        return json.loads(result.stdout)
    except subprocess.TimeoutExpired:
        print("  [!] Triage timed out (300s)", file=sys.stderr)
        return {"error": "triage timeout"}
    except json.JSONDecodeError as e:
        print(f"  [!] Triage output not valid JSON: {e}", file=sys.stderr)
        return {"error": "invalid triage output"}


def derive_tags_from_triage(triage_result: dict) -> list[str]:
    """Extract Cape routing tags from triage results."""
    triage = triage_result.get("triage", {})
    tags = triage.get("routing_tags_added", [])
    if "x64" not in tags:
        tags.insert(0, "x64")
    return tags


def derive_package_from_triage(triage_result: dict) -> str:
    """Derive Cape analysis package from triage file type detection.

    Cape uses the 'package' field to select the right analysis module.
    Without it, Cape falls back to filename extension — which fails when
    the sample has no extension (e.g., 'binary').
    """
    triage = triage_result.get("triage", {})
    file_type = triage.get("file_type", "").lower()
    file_mime = triage.get("file_mime", "").lower()

    # PE executables
    if "pe32" in file_type or file_mime == "application/x-dosexec":
        if "dll" in file_type:
            return "dll"
        return "exe"

    # Scripts
    if any(kw in file_type for kw in ["powershell", "ps1"]):
        return "ps1"
    if "python" in file_type:
        return "python"
    if "batch" in file_type or "dos batch" in file_type:
        return "bat"
    if "vbscript" in file_type or file_mime == "text/vbscript":
        return "vbs"
    if "javascript" in file_type or file_mime == "application/javascript":
        return "js"

    # Documents
    if any(kw in file_type for kw in ["word", "document", "openxml"]):
        return "doc"
    if any(kw in file_type for kw in ["excel", "spreadsheet"]):
        return "xls"
    if "pdf" in file_type or file_mime == "application/pdf":
        return "pdf"
    if "rtf" in file_type:
        return "doc"

    # Archives
    if "zip" in file_type or file_mime == "application/zip":
        return "zip"
    if "rar" in file_type:
        return "rar"

    # .NET / Java
    if "msil" in file_type or ".net" in file_type:
        return "exe"
    if "java" in file_type or file_mime == "application/java-archive":
        return "jar"

    # If triage detected it as ASCII text, check YARA for hints
    if "ascii text" in file_type or "text/plain" in file_mime:
        yara_matches = triage.get("yara_matches", [])
        rule_names = [m.get("rule", "").lower() for m in yara_matches]
        if any("base64" in r or "powershell" in r for r in rule_names):
            return "ps1"

    # Unknown — let Cape auto-detect
    return ""


# -------------------------------------------------------------------------
# Stage 2: Cape dynamic analysis (always)
# -------------------------------------------------------------------------

def cape_headers() -> dict:
    """Build Cape API auth headers."""
    if not CAPE_API_KEY or CAPE_API_KEY.startswith("PLACEHOLDER"):
        return {}
    return {"Authorization": f"Token {CAPE_API_KEY}"}


def derive_filename(sample_path: Path, package: str, original_name: str = "") -> str:
    """Derive a meaningful filename for Cape submission.

    Priority: original_name (from sample-feeder) > sample_path name with
    triage-derived extension > sample_path name as-is.
    """
    if original_name:
        return original_name
    name = sample_path.name
    if "." not in name and package:
        # No extension — append one from the detected package
        ext_map = {
            "exe": ".exe", "dll": ".dll", "ps1": ".ps1", "bat": ".bat",
            "vbs": ".vbs", "js": ".js", "doc": ".doc", "xls": ".xls",
            "pdf": ".pdf", "zip": ".zip", "rar": ".rar", "jar": ".jar",
            "python": ".py",
        }
        ext = ext_map.get(package, "")
        if ext:
            name = f"{name}{ext}"
    return name


def submit_to_cape(sample_path: Path, tags: list[str], package: str = "",
                   filename: str = "", custom: str = "") -> int:
    """Submit sample to Cape API. Returns task ID."""
    url = f"{CAPE_API_URL}/tasks/create/file/"
    submit_name = filename or sample_path.name
    data = {
        "tags": ",".join(tags),
        "memory": "1",
        "custom": custom,
    }
    if package:
        data["package"] = package
    with sample_path.open("rb") as fh:
        resp = requests.post(
            url,
            files={"file": (submit_name, fh)},
            data=data,
            headers=cape_headers(),
            timeout=30,
        )
    resp.raise_for_status()
    result = resp.json()
    if result.get("error"):
        raise ValueError(f"Cape submission error: {result.get('error_value', result)}")
    return result["data"]["task_ids"][0]


def poll_cape_task(task_id: int) -> dict:
    """Poll Cape API until task is reported or timeout."""
    url = f"{CAPE_API_URL}/tasks/view/{task_id}/"
    start = time.time()
    last_status = ""

    while time.time() - start < CAPE_TIMEOUT:
        try:
            resp = requests.get(url, headers=cape_headers(), timeout=10)
            resp.raise_for_status()
            data = resp.json().get("data", {})
            status = data.get("status", "unknown")

            if status != last_status:
                elapsed = int(time.time() - start)
                print(f"  Cape task {task_id}: {status} ({elapsed}s)")
                last_status = status

            if status == "reported":
                return data

        except requests.RequestException as e:
            print(f"  [!] Cape API error: {e}", file=sys.stderr)

        time.sleep(CAPE_POLL_INTERVAL)

    print(f"  [!] Cape timeout after {CAPE_TIMEOUT}s", file=sys.stderr)
    return {"status": "timeout", "id": task_id}


# -------------------------------------------------------------------------
# Stage 3: Volatility memory forensics
# -------------------------------------------------------------------------

def get_cape_signatures(cape_data: dict) -> list[str]:
    """Extract signature names from Cape task data."""
    # Cape stores signatures in the full report, not the task view.
    # Check the storage path for the report JSON.
    task_id = cape_data.get("id") or cape_data.get("task_id")
    if not task_id:
        return []
    report_path = Path(f"/opt/CAPEv2/storage/analyses/{task_id}/reports/report.json")
    if not report_path.exists():
        return []
    try:
        with report_path.open() as f:
            report = json.load(f)
        return [s.get("name", "") for s in report.get("signatures", [])]
    except (json.JSONDecodeError, KeyError):
        return []


def should_run_volatility(cape_data: dict) -> bool:
    """Check if Cape signatures trigger Volatility analysis."""
    if cape_data.get("status") != "reported":
        return False
    if not Path(VOLATILITY_CMD).exists():
        return False
    sigs = get_cape_signatures(cape_data)
    return any(sig in VOLATILITY_TRIGGERS for sig in sigs)


def get_memory_dump_path(cape_data: dict) -> Path | None:
    """Find the memory dump from Cape's analysis storage."""
    task_id = cape_data.get("id") or cape_data.get("task_id")
    if not task_id:
        return None
    # Cape stores memory dumps at storage/analyses/<id>/memory.dmp
    dump_path = Path(f"/opt/CAPEv2/storage/analyses/{task_id}/memory.dmp")
    if dump_path.exists():
        return dump_path
    return None


def determine_extra_plugins(cape_data: dict) -> list[str]:
    """Determine which extra Volatility plugins to run based on triggers."""
    sigs = get_cape_signatures(cape_data)
    extras = set()
    for category, config in VOLATILITY_EXTRA_PLUGINS.items():
        triggers = config.get("triggers", [])
        plugins = config.get("plugins", [])
        if any(sig in triggers for sig in sigs):
            extras.update(plugins)
    return sorted(extras)


def run_single_plugin(dump_path: Path, plugin: str, output_dir: Path) -> dict:
    """Run a single Volatility plugin. Returns parsed JSON or error."""
    try:
        result = subprocess.run(
            [VOLATILITY_CMD, str(dump_path), plugin, str(output_dir)],
            capture_output=True,
            text=True,
            timeout=300,
        )
        if result.returncode != 0:
            return {"error": result.stderr[:200]}
        return json.loads(result.stdout)
    except subprocess.TimeoutExpired:
        return {"error": f"timeout (300s)"}
    except json.JSONDecodeError:
        # Volatility JSON output may have extra lines — try to extract
        lines = result.stdout.strip().split("\n")
        for line in lines:
            try:
                return json.loads(line)
            except json.JSONDecodeError:
                continue
        return {"error": "invalid JSON output", "raw": result.stdout[:500]}


def run_volatility(cape_data: dict, output_dir: Path) -> dict:
    """Run Volatility 3 plugins on the memory dump."""
    dump_path = get_memory_dump_path(cape_data)
    if not dump_path:
        return {"triggered": True, "error": "memory dump not found"}

    sigs = get_cape_signatures(cape_data)
    trigger_sigs = [s for s in sigs if s in VOLATILITY_TRIGGERS]
    extra_plugins = determine_extra_plugins(cape_data)
    all_plugins = VOLATILITY_STANDARD_PLUGINS + extra_plugins

    result = {
        "triggered": True,
        "trigger_signatures": trigger_sigs,
        "plugins_run": [p.replace("windows.", "") for p in all_plugins],
        "plugins": {},
        "summary": {
            "injected_processes": 0,
            "suspicious_connections": 0,
        },
    }

    for plugin in all_plugins:
        short_name = plugin.replace("windows.", "")
        print(f"    Running {plugin}...")
        plugin_output = run_single_plugin(dump_path, plugin, output_dir)
        result["plugins"][short_name] = plugin_output

        # Build summary from key plugins
        if short_name == "malfind" and isinstance(plugin_output, list):
            result["summary"]["injected_processes"] = len(plugin_output)
        elif short_name == "netscan" and isinstance(plugin_output, list):
            result["summary"]["suspicious_connections"] = len(plugin_output)

    # Clean up memory dump immediately after processing
    print(f"    Cleaning up memory dump ({dump_path.stat().st_size // (1024*1024)} MB)...")
    dump_path.unlink(missing_ok=True)

    return result


# -------------------------------------------------------------------------
# Stage 4: Ghidra (stub — wired up in sub-project 4)
# -------------------------------------------------------------------------

def should_run_ghidra(cape_data: dict) -> bool:
    """Check if Cape dropped payloads trigger Ghidra analysis."""
    return False  # Stub: always false until sub-project 4


def run_ghidra(cape_data: dict, output_dir: Path) -> dict:
    """Run Ghidra headless on dropped PEs. Stub — returns not triggered."""
    return {"triggered": False, "reason": "ghidra container not yet deployed"}


# -------------------------------------------------------------------------
# Report output
# -------------------------------------------------------------------------

def write_report(task_id: str, report: dict, reports_dir: Path) -> Path:
    """Write merged report to disk."""
    report_dir = reports_dir / task_id
    report_dir.mkdir(parents=True, exist_ok=True)
    report_path = report_dir / "report.json"
    with report_path.open("w") as f:
        json.dump(report, f, indent=2, default=str)
    return report_path


# -------------------------------------------------------------------------
# Main pipeline
# -------------------------------------------------------------------------

def run_pipeline(sample_path: Path, task_id: str, original_name: str = "") -> dict:
    """Execute the four-stage analysis pipeline."""
    report = {
        "task_id": task_id,
        "sample": str(sample_path),
        "sample_name": original_name or sample_path.name,
        "started_at": datetime.now(timezone.utc).isoformat(),
    }

    output_dir = REPORTS_DIR / task_id
    output_dir.mkdir(parents=True, exist_ok=True)

    # Stage 1: Triage (always)
    print(f"\n[Stage 1] Triage: {report['sample_name']}")
    triage_result = run_triage(sample_path, output_dir)
    report.update(triage_result)
    cape_tags = derive_tags_from_triage(triage_result)
    cape_package = derive_package_from_triage(triage_result)
    cape_filename = derive_filename(sample_path, cape_package, original_name)
    print(f"  Tags: {cape_tags}")
    if cape_package:
        print(f"  Package: {cape_package}")
    print(f"  Filename: {cape_filename}")

    # Stage 2: Cape (always, with triage-informed tags, package, and filename)
    print(f"\n[Stage 2] Cape: submitting with tags={cape_tags}, package={cape_package or 'auto'}, memory=1")
    try:
        cape_task_id = submit_to_cape(
            sample_path,
            tags=cape_tags,
            package=cape_package,
            filename=cape_filename,
            custom=f"pipeline_task_id={task_id}",
        )
        print(f"  Cape task ID: {cape_task_id}")
        cape_data = poll_cape_task(cape_task_id)
        report["cape"] = {
            "task_id": cape_task_id,
            "status": cape_data.get("status", "unknown"),
        }
    except Exception as e:
        print(f"  [!] Cape submission failed: {e}", file=sys.stderr)
        report["cape"] = {"task_id": None, "status": "error", "error": str(e)}
        cape_data = {}

    # Stage 3: Volatility (triggered by Cape signatures)
    print(f"\n[Stage 3] Volatility: checking triggers...")
    if should_run_volatility(cape_data):
        print("  Triggered — running Volatility 3")
        report["volatility"] = run_volatility(cape_data, output_dir)
    else:
        print("  Not triggered (stub — awaiting sub-project 3)")
        report["volatility"] = {"triggered": False}

    # Stage 4: Ghidra (triggered by dropped payloads)
    print(f"\n[Stage 4] Ghidra: checking triggers...")
    if should_run_ghidra(cape_data):
        print("  Triggered — running Ghidra headless")
        report["ghidra"] = run_ghidra(cape_data, output_dir)
    else:
        print("  Not triggered (stub — awaiting sub-project 4)")
        report["ghidra"] = {"triggered": False}

    # Write merged report
    report["completed_at"] = datetime.now(timezone.utc).isoformat()
    report_path = write_report(task_id, report, REPORTS_DIR)
    print(f"\n[Done] Report: {report_path}")

    return report


def main():
    parser = argparse.ArgumentParser(
        prog="run-pipeline",
        description="Run the four-stage malware analysis pipeline.",
    )
    parser.add_argument("sample", type=Path, help="Path to the malware sample")
    parser.add_argument("--task-id", default=None,
                        help="Pipeline task ID (auto-generated if not set)")
    parser.add_argument("--filename", default="",
                        help="Original filename (used for Cape submission and reporting)")
    args = parser.parse_args()

    if not args.sample.exists():
        print(f"Error: file not found: {args.sample}", file=sys.stderr)
        sys.exit(1)

    task_id = args.task_id or uuid.uuid4().hex[:12]
    report = run_pipeline(args.sample, task_id, original_name=args.filename)

    # Print summary
    triage = report.get("triage", {})
    yara_count = len(triage.get("yara_matches", []))
    cape_status = report.get("cape", {}).get("status", "n/a")
    vol_triggered = report.get("volatility", {}).get("triggered", False)
    ghidra_triggered = report.get("ghidra", {}).get("triggered", False)

    print(f"\nSummary:")
    print(f"  Triage:     {yara_count} YARA matches")
    print(f"  Cape:       {cape_status}")
    print(f"  Volatility: {'triggered' if vol_triggered else 'not triggered'}")
    print(f"  Ghidra:     {'triggered' if ghidra_triggered else 'not triggered'}")


if __name__ == "__main__":
    main()
