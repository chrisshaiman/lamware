# /etc/sqs-agent/env — systemd EnvironmentFile
# Managed by Ansible — do not edit manually.
# Mode 0600, owned by {{ sqs_agent_user }} — contains long-lived IAM key.
# The key is scoped to sts:AssumeRole only; all real permissions require
# assuming ROLE_ARN, which issues 1-hour sessions.
# Cape API key is NOT stored here — the agent fetches it at runtime from
# Secrets Manager using its assumed-role credentials.

AWS_ACCESS_KEY_ID={{ baremetal_creds.access_key_id }}
AWS_SECRET_ACCESS_KEY={{ baremetal_creds.secret_access_key }}
ROLE_ARN={{ baremetal_creds.role_arn }}
SQS_QUEUE_URL={{ baremetal_creds.sqs_queue_url }}
AWS_REGION={{ baremetal_creds.aws_region }}

REPORTS_BUCKET={{ s3_bucket_reports }}
SAMPLES_BUCKET={{ s3_bucket_samples }}

CAPE_API_URL={{ cape_api_url }}
CAPE_API_SECRET_ARN={{ secret_arn_cape }}

POLL_WAIT_SECONDS={{ sqs_agent_poll_wait_seconds }}
CAPE_TIMEOUT_SECONDS={{ sqs_agent_cape_timeout_seconds }}
CAPE_POLL_INTERVAL={{ sqs_agent_cape_poll_interval_seconds }}
SESSION_REFRESH_BUFFER={{ sqs_agent_session_refresh_buffer_seconds }}
MAX_SAMPLE_BYTES={{ sqs_agent_max_sample_bytes }}
